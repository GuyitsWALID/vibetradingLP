# ================================
# DATABASE
# ================================
DATABASE_URL="postgresql://user:password@localhost:5432/vibetrading"
# For local dev fallback:
# DATABASE_URL="file:./dev.db"

# ================================
# REDIS
# ================================
REDIS_URL="redis://localhost:6379"
# Upstash compatible:
# REDIS_URL="rediss://default:password@host:6379"

# ================================
# JWT
# ================================
JWT_SECRET="change-this-to-a-cryptographically-secure-random-string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ================================
# MARKET DATA
# ================================
TWELVE_DATA_API_KEY=""

# ================================
# NEWS SQUAWK
# ================================
FJ_API_KEY=""
FJ_WS_URL="wss://api.financialjuice.com"

# ================================
# ECONOMIC CALENDAR
# ================================
FF_CALENDAR_URL="https://nfs.faireconomy.media/ff_calendar_thisweek.xml"
FF_CALENDAR_THISWEEK="https://nfs.faireconomy.media/ff_calendar_thisweek.xml"
FF_CALENDAR_NEXTWEEK="https://nfs.faireconomy.media/ff_calendar_nextweek.xml"

# ================================
# APPLICATION
# ================================
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ================================
# NODE ENV
# ================================
NODE_ENV="development"
